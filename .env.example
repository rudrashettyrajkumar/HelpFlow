# HelpFlow — environment. Copy to .env (gitignored) and fill in. Zero secrets in
# the repo: every value here is BLANK. Mirrors ARCHITECTURE §4/§7/§9 and
# backend/utils/config.py (the single source of truth). n8n reads its own $env
# in the Railway service (see the E1 checklists), not this file.

# --- Runtime ---------------------------------------------------------------
ENV=dev                       # dev | prod (prod fails fast on any missing required key)
FRONTEND_ORIGIN=*             # comma-separated allowed origins for widget/console CORS

# --- Demo-mode models (v2 — BYOK covers everything else; migrate by env
# alone, never hardcode a model string). Free-tier open-source ONLY. ---------
DEMO_REWRITER_MODEL=groq/llama-3.3-70b-versatile                        # route + rewrite + intent
DEMO_ANSWERER_MODEL=groq/llama-3.3-70b-versatile                        # grounded streamed answer
DEMO_EMBED_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free   # 768-dim, crawl + queries

# --- LLM / embedding providers (demo mode; BYOK keys arrive per-request) ---
OPENROUTER_API_KEY=           # demo diverse-fallback + embeddings — REQUIRED in prod
GROQ_API_KEY=                 # demo primary chat provider — REQUIRED in prod
GEMINI_API_KEY=               # optional: unused by demo mode (Groq/OpenRouter only)

# --- Demo-mode shared daily budget (Upstash hf:demo:{yyyymmdd}:*) ----------
DEMO_CHAT_DAILY=150           # shared chat calls/day across all demo-mode visitors
DEMO_EMBED_DAILY=100          # shared embed calls/day across all demo-mode visitors

# --- Rerank (FlashRank, ~4MB ONNX, degrades to no-op if unavailable) -------
RERANK_ENABLED=true           # FlashRank cross-encoder rerank on/off

# --- Vectors (Qdrant Cloud) ------------------------------------------------
QDRANT_URL=                   # cluster URL — REQUIRED in prod
QDRANT_API_KEY=               # cluster api key — REQUIRED in prod
QDRANT_COLLECTION=helpflow_chunks   # 768-dim cosine collection (do not change)

# --- Supabase / Postgres ---------------------------------------------------
SUPABASE_DB_URL=              # SESSION POOLER connection string (asyncpg) — REQUIRED in prod
SUPABASE_URL=                 # project URL (console/PostgREST side)
SUPABASE_ANON_KEY=            # anon key — console reads masked views only
SUPABASE_SERVICE_KEY=         # service-role key — server-side tooling only, never shipped

# --- Cache / rate limits (Upstash Redis, hf: prefix) -----------------------
UPSTASH_URL=                  # Upstash REST URL — REQUIRED in prod
UPSTASH_TOKEN=                # Upstash REST token — REQUIRED in prod

# --- Shared secrets --------------------------------------------------------
ADMIN_TOKEN=                  # bearer gating owner /admin/* routes — REQUIRED in prod
HANDOFF_TOKEN=                # X-Handoff-Token shared with n8n WF-H — REQUIRED in prod
N8N_HANDOFF_URL=              # where the brain POSTs the handoff webhook (n8n WF-H)

# --- Accounts / JWT (ARCHITECTURE §7.1) -------------------------------------
JWT_SECRET=                   # HS256 signing key for our own auth JWT — REQUIRED in prod
JWT_TTL_DAYS=7                # token lifetime

# --- Premium gate (ARCHITECTURE §3.0/§5.3/§7.2) -----------------------------
RAJ_LINKEDIN_URL=             # contact link on the trial-limit gate
RAJ_WHATSAPP_URL=             # contact link on the trial-limit gate
RAJ_EMAIL=                    # contact link on the trial-limit gate
LEAD_TOKEN=                   # X-Lead-Token shared with n8n WF-P (premium-lead notify)
N8N_PREMIUM_LEAD_URL=         # where the brain POSTs the premium-lead webhook (n8n WF-P)
PREMIUM_CONTACT_DAILY_PER_IP=3 # POST /api/premium-contact rate limit (abuse guard on the lead form)

# --- Trial caps (ARCHITECTURE §5.3) -----------------------------------------
MAX_TRIAL_PAGES=25             # crawl cap for plan='trial' workspaces (clamps MAX_PAGES)
TRIAL_MESSAGES_DAILY=40        # daily message cap for plan='trial' workspaces

# --- Tunables (escalation / crawl / concurrency) ---------------------------
MAX_CONCURRENT_LLM_CALLS=8    # global semaphore over the LangChain gateway
MAX_PAGES=50                  # crawl cap per source
CHUNK_TOKENS=450              # chunk size (tokens)
CHUNK_OVERLAP=80              # chunk overlap (tokens)
EMBED_BATCH_SIZE=100          # embeddings per request
RELEVANCE_THRESHOLD=0.30      # best cosine below this ⇒ escalate, don't guess
SENSITIVE_INTENTS=refund,complaint,cancel,human   # intents that always reach a human

# --- Rate limits (ARCHITECTURE §7) -----------------------------------------
RATE_MESSAGES_PER_CONVO_HOUR=30   # widget/WhatsApp chat messages per conversation per hour
RATE_MESSAGES_PER_TENANT_DAY=200  # premium-plan chat messages per tenant per day
RATE_CRAWLS_PER_TENANT_DAY=4      # POST /admin/sources crawls per tenant per day
