      "typeVersion": 2.5,
      "position": [
        1240,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT string_agg(role || ': ' || left(body, 140), E'\\n' ORDER BY created_at DESC) AS transcript_preview\n  FROM (\n    SELECT role, body, created_at FROM messages\n     WHERE conversation_id = $1\n     ORDER BY created_at DESC\n     LIMIT 3\n  ) recent",
        "options": {
          "queryReplacement": "={{ [$('Guarded Escalation Update').item.json.conversation_id] }}"
        }
      }
