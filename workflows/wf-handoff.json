      "typeVersion": 2.5,
      "position": [
        760,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE escalations\n   SET status = 'notified', notified_at = now()\n WHERE conversation_id = $1 AND status = 'open'\nRETURNING id AS escalation_id, conversation_id, reason",
        "options": {
          "queryReplacement": "={{ [$json.body.conversation_id] }}"
        }
      }
