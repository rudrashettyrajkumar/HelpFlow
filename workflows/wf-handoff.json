      "typeVersion": 2.5,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.id AS conversation_id, c.channel, c.customer_email, t.name AS tenant_name\n  FROM conversations c\n  JOIN tenants t ON t.id = c.tenant_id\n WHERE c.id = $1",
        "options": {
